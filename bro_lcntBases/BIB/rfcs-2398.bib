PAGES=35,
DAY=7,
MONTH=jul,
YEAR=1992,
ABSTRACT={This memo presents an elaboration of the SNMP administrative
model set forth in RFC XXX. This model provides a unified conceptual
basis for administering SNMP protocol entities to support o
authentication and integrity, o privacy, o access control, and o the
cooperation of multiple protocol entities. Please send comments to the
SNMP Security Developers mailing list (snmp-sec-dev@tis.com).},
URL="ftp://ftp.isi.edu/in-notes/rfc1351.txt",
}

