@TECHREPORT{RFC-2301,
AUTHOR="Buckley, R. and McIntyre, L. and Parsons, G. and Rafferty, J.
and Venable, D. and Zilles, S.",
TITLE="File Format for Internet Fax",
TYPE="Request for Comments (Proposed Standard)",
