}

@TECHREPORT{RFC-1609,
AUTHOR="Mansfield, G. and Johannsen, T. and Knopper, M.",
TITLE="Charting Networks in the {X.500} Directory",
TYPE="Request for Comments (Experimental)",
INSTITUTION="Internet Engineering Task Force",
NUMBER=1609,
PAGES=15,
DAY=3,
MONTH=mar,
YEAR=1994,
ABSTRACT="There is a need for a framework wherein the infrastructural
