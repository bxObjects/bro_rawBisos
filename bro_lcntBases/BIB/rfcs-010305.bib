@TECHREPORT{RFC-1269,
AUTHOR="Willis, S. and Burruss, J. W.",
TITLE="Definitions of Managed Objects for the Border Gateway Protocol:
Version 3",
TYPE="Request for Comments",
INSTITUTION="Internet Engineering Task Force",
