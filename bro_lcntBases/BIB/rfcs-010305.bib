@TECHREPORT{RFC-1924,
AUTHOR="Elz, R.",
TITLE="A Compact Representation of {IPv6} Addresses",
TYPE="Request for Comments",
INSTITUTION="Internet Engineering Task Force",
NUMBER=1924,
