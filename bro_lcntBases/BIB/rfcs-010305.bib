}

@TECHREPORT{RFC-2858,
AUTHOR="Bates, T. and Rekhter, Y. and Chandra, R. and Katz, D.",
TITLE="Multiprotocol Extensions for {BGP-4}",
TYPE="Request for Comments",
INSTITUTION="Internet Engineering Task Force",
NUMBER=2858,
MONTH=jun,
YEAR=2000,
