NUMBER=2463,
MONTH=dec,
YEAR=1998,
ABSTRACT="This document specifies a set of Internet Control Message
Protocol (ICMP) messages for use with version 6 of the Internet Protocol
(IPv6).",
URL="ftp://ftp.isi.edu/in-notes/rfc2463.txt"
}

@TECHREPORT{RFC-2464,
