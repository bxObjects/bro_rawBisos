@TECHREPORT{RFC-1599,
AUTHOR="Kennedy, M.",
TITLE="Summary of 1500-1599",
TYPE="Request for Comments",
INSTITUTION="Internet Engineering Task Force",
NUMBER=1599,
MONTH=jan,
YEAR=1997,
ABSTRACT="This RFC is a slightly annotated list of the 100 RFCs from RFC
