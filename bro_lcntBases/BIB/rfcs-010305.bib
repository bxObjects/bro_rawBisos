@TECHREPORT{RFC-2102,
AUTHOR="Ramanathan, R.",
TITLE="Multicast Support for Nimrod : Requirements and Solution
Approaches",
TYPE="Request for Comments",
INSTITUTION="Internet Engineering Task Force",
