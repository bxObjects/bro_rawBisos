@TECHREPORT{RFC-2654,
AUTHOR="Hedberg, R. and Greenblatt, B. and Moats, R. and Wahl, M.",
TITLE="A Tagged Index Object for use in the Common Indexing Protocol",
TYPE="Request for Comments",
