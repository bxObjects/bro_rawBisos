TITLE="Internet Relay Chat Protocol",
TYPE="Request for Comments",
INSTITUTION="Internet Engineering Task Force",
NUMBER=1459,
MONTH=may,
YEAR=1993,
ABSTRACT="The IRC protocol was developed over the last 4 years since it
