@TECHREPORT{RFC-2655,
AUTHOR="Hardie, T. and Bowman, M. and Hardy, D. and Schwartz, M. and
Wessels, D.",
TITLE="{CIP} Index Object Format for {SOIF} Objects",
TYPE="Request for Comments",
INSTITUTION="Internet Engineering Task Force",
NUMBER=2655,
